{
  "projectType": "cli-tool",
  "projectName": "Skada Firebreak",
  "projectDescription": "A VM-first control plane for running AI coding agents (Codex, Claude Code) in isolated KVM-backed MicroVMs with a small, clear public interface.",
  "theme": "aspen",
  "primaryColor": "#fcc72c",
  "lightColor": "#f5d8d5",
  "darkColor": "#1c3c44",
